import os

Import("env")
with open(env["PROJECT_TOOL_S"]) as f:
    exec(f.read())


SRCS = Glob("src/*.c*")
INCLUDE = [ADir("."), ADir("include")]
PRIVATE_INCLUDE = []
REQUIREMENTS = ["lvgl_component", "pthread"]
STATIC_LIB = []
DYNAMIC_LIB = []
DEFINITIONS = []
DEFINITIONS_PRIVATE = []
LDFLAGS = []
LINK_SEARCH_PATH = []
STATIC_FILES = []

# 添加ui目录
SRCS += append_srcs_dir(ADir("ui"))
INCLUDE += ["ui"]


# 为 lvgl_component 添加 SDL2 依赖
lvgl_component = list(
    filter(lambda x: x["target"] == "lvgl_component", env["COMPONENTS"])
)[0]
if "CONFIG_V9_5_LV_USE_SDL" in os.environ:
    lvgl_component["REQUIREMENTS"] += ["SDL2"]
    sdl_include_candidates = [
        "/opt/homebrew/include",
        "/usr/local/include",
        "/usr/include",
        "/opt/homebrew/include/SDL2",
        "/usr/local/include/SDL2",
        "/usr/include/SDL2",
    ]
    for include_dir in sdl_include_candidates:
        if os.path.exists(include_dir):
            lvgl_component["INCLUDE"].append(include_dir)

    sdl_library_candidates = [
        "/opt/homebrew/lib",
        "/usr/local/lib",
    ]
    for library_dir in sdl_library_candidates:
        if os.path.exists(library_dir):
            lvgl_component["LINK_SEARCH_PATH"].append(library_dir)

    lvgl_component["DEFINITIONS"] += ["-D_REENTRANT"]


env["COMPONENTS"].append(
    {
        "target": "M5CardputerZero-UserDemo",
        "SRCS": SRCS,
        "INCLUDE": INCLUDE,
        "PRIVATE_INCLUDE": PRIVATE_INCLUDE,
        "REQUIREMENTS": REQUIREMENTS,
        "STATIC_LIB": STATIC_LIB,
        "DYNAMIC_LIB": DYNAMIC_LIB,
        "DEFINITIONS": DEFINITIONS,
        "DEFINITIONS_PRIVATE": DEFINITIONS_PRIVATE,
        "LDFLAGS": LDFLAGS,
        "LINK_SEARCH_PATH": LINK_SEARCH_PATH,
        "STATIC_FILES": STATIC_FILES,
        "REGISTER": "project",
    }
)
